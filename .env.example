# =============================================================================
# XTV-SupportBot — example configuration
# Copy this file to .env and fill in the required values (marked "required").
# Every section after "Core" is optional and gated by a feature flag.
# =============================================================================

# --- Telegram (required) -----------------------------------------------------
# Create an app at https://my.telegram.org to obtain API_ID and API_HASH.
API_ID=
API_HASH=

# Bot token from @BotFather
BOT_TOKEN=

# --- MongoDB (required) ------------------------------------------------------
MONGO_URI=
MONGO_DB_NAME=xtv_support

# --- Roles (required) --------------------------------------------------------
# Comma-separated Telegram user IDs that bootstrap as `admin` / `owner`.
ADMIN_IDS=
# The forum supergroup where ticket topics are created.
# The bot MUST be an admin with the "Manage Topics" permission.
# IDs typically begin with -100 for supergroups.
ADMIN_CHANNEL_ID=

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=false
DEBUG_MODE=false

# --- SLA ---------------------------------------------------------------------
SLA_WARN_MINUTES=30
SLA_BREACH_MINUTES=120

# --- Auto-Close --------------------------------------------------------------
AUTO_CLOSE_DAYS=7
AUTO_CLOSE_SWEEP_MINUTES=10

# --- Anti-Spam / Cooldown ----------------------------------------------------
COOLDOWN_RATE=10
COOLDOWN_WINDOW=60
COOLDOWN_MUTE_SECONDS=300

# --- Broadcast ---------------------------------------------------------------
BROADCAST_CONCURRENCY=20
BROADCAST_FLOOD_BUFFER_MS=250

# --- UI ----------------------------------------------------------------------
PROGRESS_EDIT_INTERVAL=1.5
TOPIC_CREATE_RETRY=3
ERROR_LOG_TOPIC_ID=

# --- Audit & localization ----------------------------------------------------
AUDIT_RETENTION_DAYS=90
DEFAULT_LANG=en

# =============================================================================
# Optional: Redis (cache, distributed cooldown, locks)  — pip extra: redis
# =============================================================================
# REDIS_URL=redis://localhost:6379/0
# REDIS_NAMESPACE=xtv

# =============================================================================
# Optional: AI via LiteLLM  — pip extra: ai
# =============================================================================
# FEATURE_AI_DRAFTS=false
# FEATURE_AI_SUMMARY=false
# FEATURE_AI_SENTIMENT=false
# FEATURE_AI_ROUTING=false
# FEATURE_AI_TRANSLATE=false
# FEATURE_AI_TRANSCRIBE=false
#
# AI_MODEL_DEFAULT=anthropic/claude-sonnet-4-5
# AI_MODEL_FAST=anthropic/claude-haiku-4-5
# AI_MODEL_VISION=anthropic/claude-sonnet-4-5
# AI_MODEL_TRANSCRIBE=openai/whisper-1
# AI_MAX_TOKENS=1024
# AI_TEMPERATURE=0.4
# AI_REQUEST_TIMEOUT_S=30
# AI_PII_REDACTION=true
#
# One of the provider keys (or several — LiteLLM picks per model):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# =============================================================================
# REST API + Web admin
# =============================================================================
# Set API_ENABLED=true to expose /health, /ready, /api/v1/*.
# On Railway/Render/Fly/Heroku, the platform injects $PORT automatically,
# which takes precedence over API_PORT.
API_ENABLED=false
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed origins for the admin SPA (CORS).
# Leave blank to disable CORS; use "*" to allow every origin.
API_CORS_ORIGINS=
API_RATE_LIMIT_PER_MINUTE=120

# =============================================================================
# Optional: Object storage (S3 / R2 / MinIO)  — pip extra: storage
# =============================================================================
# STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# =============================================================================
# Optional: Observability  — pip extra: observability
# =============================================================================
# METRICS_ENABLED=false
# METRICS_PATH=/metrics
#
# OTEL_SERVICE_NAME=xtv-support
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1

# =============================================================================
# Optional: Outgoing webhooks + bridges
# =============================================================================
# WEBHOOK_SECRET=                     # default HMAC secret for webhooks without own secret
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=

# =============================================================================
# Optional: Email ingestion plugin
# =============================================================================
# EMAIL_INGRESS_ENABLED=false
# EMAIL_IMAP_HOST=
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=
# EMAIL_IMAP_PASSWORD=
# EMAIL_IMAP_FOLDER=INBOX
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=

# =============================================================================
# Optional: Business hours / CSAT / Analytics feature flags
# =============================================================================
# FEATURE_BUSINESS_HOURS=false
# FEATURE_CSAT=false
# FEATURE_ANALYTICS_DIGEST=false
# FEATURE_KB_GATE=false              # pre-ticket FAQ gate
# FEATURE_LINK_SCANNER=true
# FEATURE_START_CAPTCHA=false
