# --- Telegram ---
# Create an app at https://my.telegram.org to obtain API_ID and API_HASH.
API_ID=
API_HASH=

# Bot token from @BotFather
BOT_TOKEN=

# --- MongoDB ---
# Connection URI (MongoDB Atlas or self-hosted)
MONGO_URI=

# --- Roles ---
# Comma-separated Telegram user IDs that have admin access to the bot.
ADMIN_IDS=

# The forum supergroup where ticket topics are created.
# The bot MUST be an admin with the "Manage Topics" permission.
# IDs typically begin with -100 for supergroups.
ADMIN_CHANNEL_ID=

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- SLA ---
# Minutes until the first SLA warning fires on an unanswered ticket.
SLA_WARN_MINUTES=30
# Minutes until an SLA breach escalation fires.
SLA_BREACH_MINUTES=120

# --- Auto-Close ---
# Days of inactivity (no user or admin message) until a ticket is auto-closed.
AUTO_CLOSE_DAYS=7
# How often the auto-close sweeper runs (minutes).
AUTO_CLOSE_SWEEP_MINUTES=10

# --- Anti-Spam / Cooldown ---
# Max user messages allowed within the window before triggering a cooldown.
COOLDOWN_RATE=10
# Cooldown window in seconds.
COOLDOWN_WINDOW=60
# How long a user is muted after triggering the cooldown (seconds).
COOLDOWN_MUTE_SECONDS=300

# --- Broadcast ---
BROADCAST_CONCURRENCY=20
BROADCAST_FLOOD_BUFFER_MS=250

# --- UI ---
# Minimum seconds between progress-card edits.
PROGRESS_EDIT_INTERVAL=1.5

# --- Topic creation ---
TOPIC_CREATE_RETRY=3

# --- Optional: where the bot posts internal error reports. ---
# Leave empty to disable.
ERROR_LOG_TOPIC_ID=

# --- Audit log ---
AUDIT_RETENTION_DAYS=90

# --- Localization ---
DEFAULT_LANG=en
