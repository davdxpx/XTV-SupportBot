# =============================================================================
# XTV-SupportBot — configuration
#
# Copy to .env and fill in the REQUIRED block. That's all you need to boot.
#
# Everything operational — SLA timers, auto-close, topic auto-delete,
# anti-spam cooldown, broadcast tuning, branding, default UI mode / language,
# and all feature flags — is configured LIVE in the admin console
# (Settings page, or the bot's /admin → Settings). No redeploy, no env vars.
# See docs/reference/env.md for the full list and the old-var → Settings map.
# =============================================================================

# --- REQUIRED ----------------------------------------------------------------
# Telegram app credentials — create an app at https://my.telegram.org
API_ID=
API_HASH=
# Bot token from @BotFather
BOT_TOKEN=

# MongoDB connection + database name
MONGO_URI=
MONGO_DB_NAME=xtv_support

# Comma-separated Telegram user IDs that bootstrap as admin / owner
ADMIN_IDS=
# The forum supergroup where ticket topics are created. The bot MUST be an
# admin there with the "Manage Topics" permission. IDs usually start with -100.
ADMIN_CHANNEL_ID=

# --- Infrastructure (recommended) --------------------------------------------
# Directory pyrofork writes its *.session file to. On Railway/Render/Fly/Heroku
# the cwd is EPHEMERAL — every deploy wipes the session and triggers Telegram
# FLOOD_WAIT. Mount a persistent volume and point this at it (e.g. /data).
SESSION_DIR=.

# Forum topic to mirror runtime errors into (optional but handy in prod).
ERROR_LOG_TOPIC_ID=

# Required only if you use the External User Directory (encrypts stored creds).
# EXTERNAL_DIRECTORY_ENCRYPTION_KEY=

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=false
DEBUG_MODE=false

# --- REST API + Web admin (hosting) ------------------------------------------
# Set API_ENABLED=true to expose /health, /ready, /api/v1/* and the admin SPA.
# On Railway/Render/Fly/Heroku the platform injects $PORT (wins over API_PORT).
API_ENABLED=false
API_HOST=0.0.0.0
API_PORT=8000
# Allowed CORS origins for the SPA (comma-separated; "*" = any). Blank disables
# CORS — fine when the SPA is served same-origin (WEB_ENABLED=true, default).
API_CORS_ORIGINS=
API_RATE_LIMIT_PER_MINUTE=120

# Admin web-console sessions (username/password login). The cookie is HTTPS-only
# by default; for LOCAL HTTP dev you MUST set SESSION_COOKIE_SECURE=false.
SESSION_COOKIE_SECURE=true

# Serve the built React SPA from FastAPI at "/". Set false to serve it
# separately. Build output is expected at web/dist/.
WEB_ENABLED=true

# Public HTTPS URL of the Mini-App (must match the @BotFather WebApp domain).
# Leave empty to keep the classic inline-button flow. (The chat/webapp/hybrid
# UI_MODE itself is set in the console, not here.)
WEBAPP_URL=

# =============================================================================
# OPTIONAL integrations — uncomment only what you use.
# =============================================================================

# --- Redis (cache / distributed cooldown / locks) — pip extra: redis ---------
# REDIS_URL=redis://localhost:6379/0
# REDIS_NAMESPACE=xtv

# --- AI via LiteLLM — pip extra: ai -------------------------------------------
# FEATURE_AI_DRAFTS=false
# FEATURE_AI_SUMMARY=false
# AI_MODEL_DEFAULT=anthropic/claude-sonnet-4-5
# AI_MODEL_FAST=anthropic/claude-haiku-4-5
# AI_MAX_TOKENS=1024
# AI_TEMPERATURE=0.4
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- Object storage (S3 / R2 / MinIO) — pip extra: storage -------------------
# STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- Observability — pip extra: observability --------------------------------
# METRICS_ENABLED=false
# OTEL_SERVICE_NAME=xtv-support
# OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Outgoing webhooks / bridges ---------------------------------------------
# WEBHOOK_SECRET=
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=

# --- Email ingestion plugin --------------------------------------------------
# EMAIL_INGRESS_ENABLED=false
# EMAIL_IMAP_HOST=
# EMAIL_IMAP_USER=
# EMAIL_IMAP_PASSWORD=
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=

# --- Extra feature flags -----------------------------------------------------
# FEATURE_BUSINESS_HOURS=false
# FEATURE_CSAT=false
# FEATURE_ANALYTICS_DIGEST=false
# FEATURE_KB_GATE=false
# FEATURE_LINK_SCANNER=true
# FEATURE_START_CAPTCHA=false
