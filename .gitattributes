* text=auto eol=lf

*.py      text diff=python
*.md      text
*.yaml    text
*.yml     text
*.toml    text
*.json    text
*.sh      text eol=lf
*.bat     text eol=crlf

# Binary formats
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary

# Web SPA is vendored for GitHub language stats
web/** linguist-vendored=false
web/dist/** linguist-generated=true
web/node_modules/** linguist-vendored=true
